generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TenantGroup {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  reg_code   String   @unique @db.VarChar(10)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  tenants    Tenant[]

  @@map("tenant_groups")
}

model Tenant {
  tenant_id              Int                     @id @default(autoincrement())
  tenant_group_id        Int?
  name                   String                  @db.VarChar(100)
  slug                   String                  @unique @db.VarChar(50)
  brand_color            String?                 @db.VarChar(20)
  accent_color           String?                 @db.VarChar(20)
  font_pairing           String?                 @db.VarChar(50) @default("inter_outfit")
  logo_url               String?                 @db.VarChar(255)
  is_active              Boolean                 @default(true)
  created_at             DateTime                @default(now())
  updated_at             DateTime                @updatedAt
  entitlement_status     TenantEntitlementStatus @default(prospect)
  lifetime_availed_at    DateTime?
  availed_type           String?                 @db.VarChar(50) // "One-Time", "Core", "Pro"
  region                 String?                 @db.VarChar(100)
  metadata               Json?                   // For future flexible branch config
  entitlement_reference  String?                 @db.VarChar(120)
  entitlement_notes      String?
  entitled_by_user_id    Int?
  audit_logs             AuditLog[]
  transfers_out          BranchTransferRequest[] @relation("TransferOut")
  transfers_in           BranchTransferRequest[] @relation("TransferIn")
  conversations          Conversation[]
  decommissioned_backups DecommissionedBackup[]
  feedbackEntries        FeedbackEntry[]
  homepage_faqs          HomepageFaq[]
  homepage_testimonials  HomepageTestimonial[]
  interaction_logs       InteractionLog[]
  products               LoanProduct[]
  loans                  Loan[]
  mentorship_connections MentorshipConnection[]
  messages               Message[]
  notifications          Notification[]
  payment_methods        PaymentMethod[]
  savings                SavingsAccount[]
  tenant_group           TenantGroup?            @relation(fields: [tenant_group_id], references: [id])
  traffic_logs           TrafficLog[]
  users                  User[]
  system_files           SystemFile[]
  tenantSubscription     TenantSubscription?

  @@map("tenants")
}

model User {
  user_id                   Int                       @id @default(autoincrement())
  member_code               String?                   @db.VarChar(20)
  username                  String                    @db.VarChar(50)
  email                     String                    @db.VarChar(150)
  phone                     String?                   @db.VarChar(20)
  password_hash             String                    @db.VarChar(255)
  tenant_id                 Int?
  role                      Role                      @default(member)
  status                    UserStatus                @default(pending)
  interest_tier             InterestTier              @default(T1_5_PERCENT)
  is_deactivation_locked    Boolean                   @default(false)
  deleted_at                DateTime?
  created_at                DateTime                  @default(now())
  updated_at                DateTime                  @updatedAt
  consent_accepted_at       DateTime?
  consent_version           String?                   @db.VarChar(20)
  audit_logs                AuditLog[]
  transfer_requests         BranchTransferRequest[]
  approved_compassions      CompassionAction[]        @relation("ApprovedCompassion")
  requested_compassions     CompassionAction[]        @relation("RequestedCompassion")
  conversation_participants ConversationParticipant[]
  created_conversations     Conversation[]            @relation("ConversationCreator")
  feedback_entries          FeedbackEntry[]
  interaction_logs          InteractionLog[]
  guarantees                LoanGuarantee[]           @relation("Guarantor")
  approved_loans            Loan[]                    @relation("ApprovedLoans")
  loans                     Loan[]                    @relation("UserLoans")
  endorsed_mentorships      MentorshipConnection[]    @relation("MentorshipEndorser")
  received_mentorships      MentorshipConnection[]    @relation("MentorshipMentor")
  requested_mentorships     MentorshipConnection[]    @relation("MentorshipRequester")
  message_reactions         MessageReaction[]
  sent_messages             Message[]                 @relation("SentMessages")
  notifications             Notification[]            @relation("NotificationRecipient")
  verified_payments         Payment[]                 @relation("VerifiedPayments")
  savings_accounts          SavingsAccount[]
  processed_savings         SavingsTransaction[]      @relation("ProcessedSavings")
  social_vouches_received   SocialVouch[]             @relation("Vouchee")
  social_vouches_sent       SocialVouch[]             @relation("Voucher")
  two_factor_auth           TwoFactorAuth?
  documents                 UserDocument[]
  system_files              SystemFile[] @relation("FileUploader")
  profile                   UserProfile?
  tenant                    Tenant?                   @relation(fields: [tenant_id], references: [tenant_id])

  @@unique([email, tenant_id])
  @@unique([username, tenant_id])
  @@unique([member_code, tenant_id])
  @@map("users")
}

model UserProfile {
  profile_id          Int            @id @default(autoincrement())
  user_id             Int            @unique
  first_name          String         @db.VarChar(100)
  middle_name         String?        @db.VarChar(100)
  last_name           String         @db.VarChar(100)
  gender              String?        @db.VarChar(20)
  birthdate           DateTime?      @db.Date
  address             String?
  business_name       String?        @db.VarChar(150)
  marital_status      MaritalStatus? @default(single)
  occupation          String?        @db.VarChar(150)
  mothers_maiden_name String?        @db.VarChar(150)
  place_of_birth      String?        @db.VarChar(150)
  tin                 String?        @db.VarChar(20)
  region              String?        @db.VarChar(255)
  province            String?        @db.VarChar(255)
  city                String?        @db.VarChar(255)
  barangay            String?        @db.VarChar(255)
  photo_url           String?        @db.Text
  user                User           @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserDocument {
  document_id         Int                @id @default(autoincrement())
  user_id             Int
  document_type       DocumentType
  id_type_name        String?            @db.VarChar(100)
  file_url            String             @db.Text
  verification_status VerificationStatus @default(pending)
  uploaded_at         DateTime           @default(now())
  user                User               @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("user_documents")
}

model TwoFactorAuth {
  tfa_id         Int     @id @default(autoincrement())
  user_id        Int     @unique
  totp_secret    String  @db.VarChar(255)
  is_enabled     Boolean @default(false)
  recovery_codes String?
  user           User    @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("two_factor_auth")
}

model LoanProduct {
  product_id               Int                  @id @default(autoincrement())
  name                     String               @db.VarChar(100)
  description              String?
  min_amount               Decimal              @db.Decimal(15, 2)
  max_amount               Decimal              @db.Decimal(15, 2)
  interest_rate_percent    Decimal              @db.Decimal(5, 2)
  max_term_months          Int
  is_active                Boolean              @default(true)
  tenant_id                Int
  allowed_frequencies      RepaymentFrequency[] @default([monthly])
  guarantor_liability_rate Decimal              @default(25) @db.Decimal(5, 2)
  tenant                   Tenant               @relation(fields: [tenant_id], references: [tenant_id])
  loans                    Loan[]

  @@map("loan_products")
}

model Loan {
  loan_id                 Int                @id @default(autoincrement())
  tenant_id               Int
  user_id                 Int
  product_id              Int
  loan_reference          String             @unique @db.VarChar(50)
  principal_amount        Decimal            @db.Decimal(15, 2)
  purpose                 String
  term_months             Int
  interest_applied        Decimal            @db.Decimal(15, 2)
  principal_receivable    Decimal            @default(0) @db.Decimal(15, 2)
  interest_receivable     Decimal            @default(0) @db.Decimal(15, 2)
  fees_applied            Decimal            @default(0) @db.Decimal(15, 2)
  total_payable           Decimal            @db.Decimal(15, 2)
  balance_remaining       Decimal            @db.Decimal(15, 2)
  status                  LoanStatus         @default(pending)
  applied_at              DateTime           @default(now())
  approved_at             DateTime?
  approved_by             Int?
  repayment_frequency     RepaymentFrequency @default(monthly)
  recovery_parent_loan_id Int?
  is_recovery_loan        Boolean            @default(false)
  ledger_entries          BusinessLedger[]
  compassion_actions      CompassionAction[]
  interest_audit          InterestAudit?
  guarantees              LoanGuarantee[]
  schedules               LoanSchedule[]
  approver                User?              @relation("ApprovedLoans", fields: [approved_by], references: [user_id])
  product                 LoanProduct        @relation(fields: [product_id], references: [product_id])
  recovery_parent         Loan?              @relation("RecoveryChain", fields: [recovery_parent_loan_id], references: [loan_id])
  recovery_children       Loan[]             @relation("RecoveryChain")
  tenant                  Tenant             @relation(fields: [tenant_id], references: [tenant_id])
  user                    User               @relation("UserLoans", fields: [user_id], references: [user_id])
  payments                Payment[]

  @@map("loans")
}

model LoanSchedule {
  schedule_id        Int            @id @default(autoincrement())
  loan_id            Int
  installment_number Int
  due_date           DateTime       @db.Date
  principal_amount   Decimal        @db.Decimal(15, 2)
  interest_amount    Decimal        @db.Decimal(15, 2)
  total_due          Decimal        @db.Decimal(15, 2)
  status             ScheduleStatus @default(pending)
  paid_at            DateTime?
  days_late          Int            @default(0)
  penalty_applied    Decimal        @default(0) @db.Decimal(15, 2)
  loan               Loan           @relation(fields: [loan_id], references: [loan_id], onDelete: Cascade)

  @@map("loan_schedules")
}

model PaymentMethod {
  method_id      Int       @id @default(autoincrement())
  provider_name  String    @db.VarChar(100)
  account_number String?   @db.VarChar(100)
  is_active      Boolean   @default(true)
  tenant_id      Int
  tenant         Tenant    @relation(fields: [tenant_id], references: [tenant_id])
  payments       Payment[]

  @@map("payment_methods")
}

model Payment {
  payment_id        Int           @id @default(autoincrement())
  loan_id           Int
  method_id         Int
  payment_reference String        @unique @db.VarChar(100)
  amount_paid       Decimal       @db.Decimal(15, 2)
  receipt_url       String?       @db.VarChar(255)
  status            PaymentStatus @default(pending)
  submitted_at      DateTime      @default(now())
  verified_at       DateTime?
  verified_by       Int?
  notes             String?
  loan              Loan          @relation(fields: [loan_id], references: [loan_id])
  payment_method    PaymentMethod @relation(fields: [method_id], references: [method_id])
  verifier          User?         @relation("VerifiedPayments", fields: [verified_by], references: [user_id])

  @@map("payments")
}

model SavingsAccount {
  account_id   Int                  @id @default(autoincrement())
  tenant_id    Int
  user_id      Int
  account_type AccountType
  balance      Decimal              @default(0) @db.Decimal(15, 2)
  opened_at    DateTime             @default(now())
  tenant       Tenant               @relation(fields: [tenant_id], references: [tenant_id])
  user         User                 @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  transactions SavingsTransaction[]

  @@unique([user_id, account_type])
  @@map("savings_accounts")
}

model SavingsTransaction {
  transaction_id   Int             @id @default(autoincrement())
  account_id       Int
  transaction_type TransactionType
  amount           Decimal         @db.Decimal(15, 2)
  reference        String?         @db.VarChar(100)
  processed_at     DateTime        @default(now())
  processed_by     Int?
  account          SavingsAccount  @relation(fields: [account_id], references: [account_id])
  processor        User?           @relation("ProcessedSavings", fields: [processed_by], references: [user_id])

  @@map("savings_transactions")
}

model AuditLog {
  log_id      Int      @id @default(autoincrement())
  tenant_id   Int?
  user_id     Int?
  action      String   @db.VarChar(100)
  entity_type String   @db.VarChar(50)
  entity_id   Int?
  old_values  Json?
  new_values  Json?
  ip_address  String?  @db.VarChar(45)
  user_agent  String?
  created_at  DateTime @default(now())
  city        String?  @db.VarChar(100)
  region      String?  @db.VarChar(100)
  tenant      Tenant?  @relation(fields: [tenant_id], references: [tenant_id])
  user        User?    @relation(fields: [user_id], references: [user_id])

  @@map("audit_logs")
}

model TrafficLog {
  id         String   @id @default(cuid())
  tenant_id  Int?
  path       String
  ip_address String?  @db.VarChar(45)
  city       String?  @db.VarChar(100)
  region     String?  @db.VarChar(100)
  user_agent String?
  created_at DateTime @default(now())
  tenant     Tenant?  @relation(fields: [tenant_id], references: [tenant_id])

  @@index([tenant_id, created_at])
  @@map("traffic_logs")
}

model InteractionLog {
  id         String   @id @default(cuid())
  tenant_id  Int?
  user_id    Int?
  event_type String   @db.VarChar(100)
  metadata   Json?
  ip_address String?  @db.VarChar(45)
  city       String?  @db.VarChar(100)
  region     String?  @db.VarChar(100)
  created_at DateTime @default(now())
  tenant     Tenant?  @relation(fields: [tenant_id], references: [tenant_id])
  user       User?    @relation(fields: [user_id], references: [user_id])

  @@index([tenant_id, event_type, created_at])
  @@map("interaction_logs")
}

model HomepageFaq {
  id                   Int      @id @default(autoincrement())
  tenant_id            Int?
  question             String   @db.VarChar(255)
  answer               String
  is_active            Boolean  @default(true)
  sort_order           Int      @default(0)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  season_tag           String?  @db.VarChar(100)
  workflow_status      String   @default("published") @db.VarChar(50)
  review_notes         String?
  submitted_by_user_id Int?
  reviewed_by_user_id  Int?
  tenant               Tenant?  @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)

  @@index([tenant_id, workflow_status, is_active, sort_order])
  @@map("homepage_faqs")
}

model HomepageTestimonial {
  id                   Int      @id @default(autoincrement())
  tenant_id            Int?
  name                 String   @db.VarChar(150)
  role_label           String   @db.VarChar(150)
  photo_url            String?  @db.VarChar(255)
  content              String
  season_tag           String?  @db.VarChar(100)
  is_active            Boolean  @default(true)
  sort_order           Int      @default(0)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  workflow_status      String   @default("published") @db.VarChar(50)
  review_notes         String?
  submitted_by_user_id Int?
  reviewed_by_user_id  Int?
  tenant               Tenant?  @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)

  @@index([tenant_id, workflow_status, is_active, sort_order])
  @@map("homepage_testimonials")
}

model FeedbackEntry {
  id         Int      @id @default(autoincrement())
  tenant_id  Int?
  user_id    Int?
  name       String   @db.VarChar(150)
  email      String?  @db.VarChar(150)
  category   String   @db.VarChar(100)
  page_path  String?  @db.VarChar(255)
  subject    String?  @db.VarChar(255)
  message    String
  status     String   @default("open") @db.VarChar(50)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  tenant     Tenant?  @relation(fields: [tenant_id], references: [tenant_id])
  user       User?    @relation(fields: [user_id], references: [user_id])

  @@index([tenant_id, status, created_at])
  @@index([user_id, created_at])
  @@map("feedback_entries")
}

model VerificationToken {
  id        Int      @id @default(autoincrement())
  email     String
  token     String   @unique
  expires   DateTime
  tenant_id Int?

  @@unique([tenant_id, email, token])
  @@index([tenant_id, email])
  @@map("verification_tokens")
}

model TwoFactorToken {
  id        Int      @id @default(autoincrement())
  email     String
  token     String   @unique
  expires   DateTime
  tenant_id Int?

  @@unique([tenant_id, email, token])
  @@index([tenant_id, email])
  @@map("two_factor_tokens")
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  tenant_id Int?
  email     String
  token     String   @unique
  expires   DateTime

  @@unique([tenant_id, email, token])
  @@index([tenant_id, email])
  @@map("password_reset_tokens")
}

model Message {
  id              String              @id @default(cuid())
  tenant_id       Int
  sender_id       Int
  content         String
  is_broadcast    Boolean             @default(false)
  created_at      DateTime            @default(now())
  conversation_id String
  reply_to_id     String?
  updated_at      DateTime            @updatedAt
  attachments     MessageAttachment[]
  reactions       MessageReaction[]
  conversation    Conversation        @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  reply_to        Message?            @relation("MessageReplies", fields: [reply_to_id], references: [id])
  replies         Message[]           @relation("MessageReplies")
  sender          User                @relation("SentMessages", fields: [sender_id], references: [user_id], onDelete: Cascade)
  tenant          Tenant              @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)

  @@index([conversation_id, created_at])
  @@map("messages")
}

model Conversation {
  id           String                    @id @default(cuid())
  tenant_id    Int
  type         ConversationType
  title        String?                   @db.VarChar(150)
  slug         String?                   @db.VarChar(100)
  created_by   Int?
  created_at   DateTime                  @default(now())
  updated_at   DateTime                  @updatedAt
  participants ConversationParticipant[]
  creator      User?                     @relation("ConversationCreator", fields: [created_by], references: [user_id])
  tenant       Tenant                    @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)
  messages     Message[]

  @@unique([tenant_id, type, slug])
  @@index([tenant_id, type, updated_at])
  @@map("conversations")
}

model ConversationParticipant {
  id              String       @id @default(cuid())
  conversation_id String
  user_id         Int
  joined_at       DateTime     @default(now())
  last_read_at    DateTime?
  conversation    Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@unique([conversation_id, user_id])
  @@index([user_id, last_read_at])
  @@map("conversation_participants")
}

model MentorshipConnection {
  id           String           @id @default(cuid())
  tenant_id    Int
  requester_id Int
  mentor_id    Int
  endorsed_by  Int?
  status       MentorshipStatus @default(pending_endorsement)
  focus_area   String?          @db.VarChar(150)
  notes        String?
  created_at   DateTime         @default(now())
  endorsed_at  DateTime?
  endorser     User?            @relation("MentorshipEndorser", fields: [endorsed_by], references: [user_id])
  mentor       User             @relation("MentorshipMentor", fields: [mentor_id], references: [user_id], onDelete: Cascade)
  requester    User             @relation("MentorshipRequester", fields: [requester_id], references: [user_id], onDelete: Cascade)
  tenant       Tenant           @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)

  @@unique([tenant_id, requester_id, mentor_id])
  @@index([tenant_id, status, created_at])
  @@map("mentorship_connections")
}

model MessageAttachment {
  id         String   @id @default(cuid())
  message_id String
  file_name  String   @db.VarChar(255)
  file_url   String   @db.VarChar(255)
  mime_type  String   @db.VarChar(100)
  size_bytes Int
  created_at DateTime @default(now())
  message    Message  @relation(fields: [message_id], references: [id], onDelete: Cascade)

  @@index([message_id, created_at])
  @@map("message_attachments")
}

model MessageReaction {
  id         String   @id @default(cuid())
  message_id String
  user_id    Int
  emoji      String   @db.VarChar(24)
  created_at DateTime @default(now())
  message    Message  @relation(fields: [message_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@unique([message_id, user_id, emoji])
  @@index([user_id, created_at])
  @@map("message_reactions")
}

model Notification {
  id         String              @id @default(cuid())
  tenant_id  Int?
  user_id    Int
  type       NotificationType
  title      String              @db.VarChar(150)
  body       String
  action_url String?             @db.VarChar(255)
  channel    NotificationChannel @default(in_app)
  is_read    Boolean             @default(false)
  emailed_at DateTime?
  created_at DateTime            @default(now())
  tenant     Tenant?             @relation(fields: [tenant_id], references: [tenant_id])
  recipient  User                @relation("NotificationRecipient", fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id, is_read, created_at])
  @@index([tenant_id, type, created_at])
  @@map("notifications")
}

model BranchTransferRequest {
  id             String   @id @default(cuid())
  user_id        Int
  from_tenant_id Int
  to_tenant_id   Int
  status         String   @default("PENDING")
  reason         String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  from_tenant    Tenant   @relation("TransferOut", fields: [from_tenant_id], references: [tenant_id], onDelete: Cascade)
  to_tenant      Tenant   @relation("TransferIn", fields: [to_tenant_id], references: [tenant_id], onDelete: Cascade)
  user           User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([status])
  @@map("branch_transfer_requests")
}

model DecommissionedBackup {
  id               String   @id @default(cuid())
  tenant_id        Int
  file_url         String   @db.VarChar(255)
  snapshot_date    DateTime @default(now())
  created_at       DateTime @default(now())
  snapshot_content String
  tenant           Tenant   @relation(fields: [tenant_id], references: [tenant_id])

  @@map("decommissioned_backups")
}

model LoanGuarantee {
  id             Int             @id @default(autoincrement())
  loan_id        Int
  guarantor_id   Int
  status         GuaranteeStatus @default(pending)
  vouched_at     DateTime?
  soft_freeze_at DateTime?
  hard_freeze_at DateTime?
  guarantor      User            @relation("Guarantor", fields: [guarantor_id], references: [user_id])
  loan           Loan            @relation(fields: [loan_id], references: [loan_id], onDelete: Cascade)

  @@map("loan_guarantees")
}

model CompassionAction {
  action_id    Int                  @id @default(autoincrement())
  loan_id      Int
  action_type  CompassionActionType
  reason       String
  status       CompassionStatus     @default(pending)
  requested_by Int
  requested_at DateTime             @default(now())
  approved_by  Int?
  approved_at  DateTime?
  admin_notes  String?
  approver     User?                @relation("ApprovedCompassion", fields: [approved_by], references: [user_id])
  loan         Loan                 @relation(fields: [loan_id], references: [loan_id], onDelete: Cascade)
  requester    User                 @relation("RequestedCompassion", fields: [requested_by], references: [user_id])

  @@map("compassion_actions")
}

model BusinessLedger {
  id             Int           @id @default(autoincrement())
  transaction_id String        @default(cuid())
  account_id     Int
  debit          Decimal       @default(0) @db.Decimal(15, 2)
  credit         Decimal       @default(0) @db.Decimal(15, 2)
  description    String
  ledger_hash    String?       @db.VarChar(255)
  created_at     DateTime      @default(now())
  created_by     Int?
  loan_id        Int?
  metadata       Json?
  account        LedgerAccount @relation(fields: [account_id], references: [id])
  loan           Loan?         @relation(fields: [loan_id], references: [loan_id])

  @@map("business_ledger")
}

model LedgerAccount {
  id             Int               @id @default(autoincrement())
  name           String            @db.VarChar(100)
  code           String            @unique @db.VarChar(20)
  type           LedgerAccountType
  tenant_id      Int?
  ledger_entries BusinessLedger[]

  @@map("ledger_accounts")
}

model SocialVouch {
  id         Int      @id @default(autoincrement())
  voucher_id Int
  vouchee_id Int
  score      Int      @default(5)
  comment    String?
  created_at DateTime @default(now())
  vouchee    User     @relation("Vouchee", fields: [vouchee_id], references: [user_id])
  voucher    User     @relation("Voucher", fields: [voucher_id], references: [user_id])

  @@map("social_vouches")
}

model InterestAudit {
  id               Int      @id @default(autoincrement())
  loan_id          Int      @unique
  formula_snapshot Json
  rate_applied     Decimal  @db.Decimal(5, 2)
  created_at       DateTime @default(now())
  loan             Loan     @relation(fields: [loan_id], references: [loan_id], onDelete: Cascade)

  @@map("interest_audit")
}

