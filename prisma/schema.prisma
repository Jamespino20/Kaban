enum ReportType {
  cross_tenant_financial
  tenant_performance
  lender_summary
  member_summary
  loan_portfolio
  repayment_summary
  wallet_activity
  reconciliation_summary
  trust_analysis
  audit_export
}

enum ReportFormat {
  csv
  pdf
  json
}

enum ReportStatus {
  queued
  processing
  ready
  failed
  expired
}

enum ReportScheduleFrequency {
  daily
  weekly
  monthly
  one_time
}

model ReportDefinition {
  id                Int                      @id @default(autoincrement())
  tenant_id         Int?
  created_by        Int
  name              String                   @db.VarChar(150)
  report_type       ReportType
  format            ReportFormat             @default(csv)
  filters           Json?
  is_scheduled      Boolean                  @default(false)
  schedule_freq     ReportScheduleFrequency?
  schedule_day      Int?
  next_run_at       DateTime?
  recipients        String[]
  is_active         Boolean                  @default(true)
  created_at        DateTime                 @default(now())
  updated_at        DateTime                 @updatedAt
  generated_reports GeneratedReport[]

  @@index([tenant_id, report_type])
  @@index([is_scheduled, next_run_at])
  @@map("report_definitions")
}

model GeneratedReport {
  id                  Int               @id @default(autoincrement())
  definition_id       Int?
  tenant_id           Int?
  requested_by        Int?
  report_type         ReportType
  format              ReportFormat
  status              ReportStatus      @default(queued)
  file_url            String?           @db.VarChar(512)
  file_size_bytes     Int?
  row_count           Int?
  error_message       String?
  period_start        DateTime?
  period_end          DateTime?
  dispatched_at       DateTime?
  dispatch_recipients String[]
  dispatch_status     String?           @db.VarChar(50)
  expires_at          DateTime?
  audit_log_id        Int?
  created_at          DateTime          @default(now())
  updated_at          DateTime          @updatedAt
  definition          ReportDefinition? @relation(fields: [definition_id], references: [id])

  @@index([tenant_id, report_type, created_at])
  @@index([status, created_at])
  @@index([definition_id])
  @@map("generated_reports")
}

