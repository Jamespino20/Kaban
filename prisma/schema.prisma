generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model TenantGroup {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  reg_code   String   @unique @db.VarChar(10)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  tenants    Tenant[]

  @@map("tenant_groups")
}

model Tenant {
  tenant_id                Int                       @id @default(autoincrement())
  tenant_group_id          Int?
  name                     String                    @db.VarChar(100)
  slug                     String                    @unique @db.VarChar(50)
  brand_color              String?                   @db.VarChar(20)
  accent_color             String?                   @db.VarChar(20)
  font_pairing             String?                   @default("inter_outfit") @db.VarChar(50)
  logo_url                 String?                   @db.Text
  is_active                Boolean                   @default(true)
  created_at               DateTime                  @default(now())
  updated_at               DateTime                  @updatedAt
  entitlement_status       TenantEntitlementStatus   @default(prospect)
  lifetime_availed_at      DateTime?
  availed_type             String?                   @db.VarChar(50) // "One-Time", "Core", "Pro"
  region                   String?                   @db.VarChar(100)
  metadata                 Json? // For future flexible tenant config
  entitlement_reference    String?                   @db.VarChar(120)
  entitlement_notes        String?
  entitled_by_user_id      Int?
  audit_logs               AuditLog[]
  conversations            Conversation[]
  decommissioned_backups   DecommissionedBackup[]
  feedbackEntries          FeedbackEntry[]
  homepage_faqs            HomepageFaq[]
  homepage_testimonials    HomepageTestimonial[]
  interaction_logs         InteractionLog[]
  products                 LoanProduct[]
  loans                    Loan[]
  mentorship_connections   MentorshipConnection[]
  messages                 Message[]
  notifications            Notification[]
  payment_methods          PaymentMethod[]
  savings                  SavingsAccount[]
  tenant_group             TenantGroup?              @relation(fields: [tenant_group_id], references: [id])
  traffic_logs             TrafficLog[]
  users                    User[]
  system_files             SystemFile[]
  tenantSubscription       TenantSubscription?
  topup_requests           TopUpRequest[]
  userProfiles             UserProfile[]
  userDocuments            UserDocument[]
  loanSchedules            LoanSchedule[]
  payments                 Payment[]
  savingsTransactions      SavingsTransaction[]
  conversationParticipants ConversationParticipant[]
  messageAttachments       MessageAttachment[]
  messageReactions         MessageReaction[]
  loanGuarantees           LoanGuarantee[]
  compassionActions        CompassionAction[]
  businessLedgers          BusinessLedger[]
  interestAudits           InterestAudit[]

  @@map("tenants")
}

// ============================================================
// Tenant Application (SA-03)
// ============================================================

enum TenantApplicationStatus {
  pending
  approved
  rejected
}

model TenantApplication {
  application_id      Int            @id @default(autoincrement())
  tenant_name          String         @db.VarChar(100)
  tenant_slug         String         @unique @db.VarChar(50)
  applicant_name      String?        @db.VarChar(150)
  applicant_email    String         @db.VarChar(150)
  applicant_phone    String?        @db.VarChar(20)
  estimated_members  Int?           @default(100)
  tenant_group_id     Int?
  brand_color        String?        @db.VarChar(20)
  accent_color       String?        @db.VarChar(20)
  logo_url           String?        @db.Text
  status             TenantApplicationStatus @default(pending)
  submitted_by       Int
  reviewed_by       Int?
  reviewed_at       DateTime?
  review_notes      String?
  documents         Json?
  created_at         DateTime      @default(now())
  updated_at         DateTime      @updatedAt

  @@map("tenant_applications")
}

model User {
  user_id                   Int                       @id @default(autoincrement())
  tenant_id                 Int?
  member_code               String?                   @db.VarChar(20)
  username                  String                    @db.VarChar(50)
  email                     String                    @db.VarChar(150)
  phone                     String?                   @db.VarChar(20)
  password_hash             String                    @db.VarChar(255)
  role                      Role                      @default(member)
  status                    UserStatus                @default(pending)
  interest_tier             InterestTier              @default(T1_5_PERCENT)
  is_deactivation_locked    Boolean                   @default(false)
  deleted_at                DateTime?
  created_at                DateTime                  @default(now())
  updated_at                DateTime                  @updatedAt
  consent_accepted_at       DateTime?
  consent_version           String?                   @db.VarChar(20)
  audit_logs                AuditLog[]
  approved_compassions      CompassionAction[]        @relation("ApprovedCompassion")
  requested_compassions     CompassionAction[]        @relation("RequestedCompassion")
  conversation_participants ConversationParticipant[]
  created_conversations     Conversation[]            @relation("ConversationCreator")
  feedback_entries          FeedbackEntry[]
  interaction_logs          InteractionLog[]
  submitted_faqs            HomepageFaq[]         @relation("FaqSubmitter")
  reviewed_faqs             HomepageFaq[]         @relation("FaqReviewer")
  submitted_testimonials    HomepageTestimonial[] @relation("TestimonialSubmitter")
  reviewed_testimonials     HomepageTestimonial[] @relation("TestimonialReviewer")
  guarantees                LoanGuarantee[]           @relation("Guarantor")
  approved_loans            Loan[]                    @relation("ApprovedLoans")
  loans                     Loan[]                    @relation("UserLoans")
  endorsed_mentorships      MentorshipConnection[]    @relation("MentorshipEndorser")
  received_mentorships      MentorshipConnection[]    @relation("MentorshipMentor")
  requested_mentorships     MentorshipConnection[]    @relation("MentorshipRequester")
  message_reactions         MessageReaction[]
  sent_messages             Message[]                 @relation("SentMessages")
  notifications             Notification[]            @relation("NotificationRecipient")
  verified_payments         Payment[]                 @relation("VerifiedPayments")
  savings_accounts          SavingsAccount[]
  processed_savings         SavingsTransaction[]      @relation("ProcessedSavings")
  social_vouches_received   SocialVouch[]             @relation("Vouchee")
  social_vouches_sent       SocialVouch[]             @relation("Voucher")
  two_factor_auth           TwoFactorAuth?
  documents                 UserDocument[]
  system_files              SystemFile[]              @relation("FileUploader")
  topup_requests            TopUpRequest[]
  processed_topups          TopUpRequest[]            @relation("TopUpProcessor")
  profile                   UserProfile?
  tenant                    Tenant?                   @relation(fields: [tenant_id], references: [tenant_id])

  @@unique([email, tenant_id])
  @@unique([username, tenant_id])
  @@unique([member_code, tenant_id])
  @@map("users")
}

model UserProfile {
  profile_id     Int            @id @default(autoincrement())
  user_id        Int            @unique
  tenant_id      Int // Mandatory for RLS
  first_name     String         @db.VarChar(100)
  middle_name    String?        @db.VarChar(100)
  last_name      String         @db.VarChar(100)
  gender         String?        @db.VarChar(20)
  birthdate      DateTime?      @db.Date
  address        String?
  business_name  String?        @db.VarChar(150)
  marital_status MaritalStatus? @default(single)
  occupation     String?        @db.VarChar(150)
  place_of_birth String?        @db.VarChar(150)
  tin            String?        @db.VarChar(20)
  region         String?        @db.VarChar(255)
  province       String?        @db.VarChar(255)
  city           String?        @db.VarChar(255)
  barangay       String?        @db.VarChar(255)
  photo_url      String?        @db.Text
  user           User           @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  tenant         Tenant         @relation(fields: [tenant_id], references: [tenant_id])

  @@index([tenant_id])
  @@map("user_profiles")
}

model UserDocument {
  document_id         Int                @id @default(autoincrement())
  user_id             Int
  tenant_id           Int // Mandatory for RLS
  document_type       DocumentType

  id_type_name        String?            @db.VarChar(100)
  file_url            String             @db.Text
  verification_status VerificationStatus @default(pending)
  uploaded_at         DateTime           @default(now())
  user                User               @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  tenant              Tenant             @relation(fields: [tenant_id], references: [tenant_id])

  @@index([tenant_id])
  @@map("user_documents")
}

model TwoFactorAuth {
  tfa_id         Int     @id @default(autoincrement())
  user_id        Int     @unique
  totp_secret    String  @db.VarChar(255)
  is_enabled     Boolean @default(false)
  recovery_codes String?
  user           User    @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@map("two_factor_auth")
}

model LoanProduct {
  product_id               Int                  @id @default(autoincrement())
  name                     String               @db.VarChar(100)
  description              String?
  min_amount               Decimal              @db.Decimal(15, 2)
  max_amount               Decimal              @db.Decimal(15, 2)
  interest_rate_percent    Decimal              @db.Decimal(5, 2)
  max_term_months          Int
  is_active                Boolean              @default(true)
  tenant_id                Int
  allowed_frequencies      RepaymentFrequency[] @default([monthly])
  guarantor_liability_rate Decimal              @default(25) @db.Decimal(5, 2)
  tenant                   Tenant               @relation(fields: [tenant_id], references: [tenant_id])
  loans                    Loan[]

  @@map("loan_products")
}

model Loan {
  loan_id                 Int                @id @default(autoincrement())
  tenant_id               Int
  user_id                 Int
  product_id              Int
  loan_reference          String             @unique @db.VarChar(50)
  principal_amount        Decimal            @db.Decimal(15, 2)
  purpose                 String
  term_months             Int
  interest_applied        Decimal            @db.Decimal(15, 2)
  principal_receivable    Decimal            @default(0) @db.Decimal(15, 2)
  interest_receivable     Decimal            @default(0) @db.Decimal(15, 2)
  fees_applied            Decimal            @default(0) @db.Decimal(15, 2)
  total_payable           Decimal            @db.Decimal(15, 2)
  balance_remaining       Decimal            @db.Decimal(15, 2)
  status                  LoanStatus         @default(pending)
  applied_at              DateTime           @default(now())
  approved_at             DateTime?
  approved_by             Int?
  repayment_frequency     RepaymentFrequency @default(monthly)
  recovery_parent_loan_id Int?
  is_recovery_loan        Boolean            @default(false)
  ledger_entries          BusinessLedger[]
  compassion_actions      CompassionAction[]
  interest_audit          InterestAudit?
  guarantees              LoanGuarantee[]
  schedules               LoanSchedule[]
  approver                User?              @relation("ApprovedLoans", fields: [approved_by], references: [user_id])
  product                 LoanProduct        @relation(fields: [product_id], references: [product_id])
  recovery_parent         Loan?              @relation("RecoveryChain", fields: [recovery_parent_loan_id], references: [loan_id])
  recovery_children       Loan[]             @relation("RecoveryChain")
  tenant                  Tenant             @relation(fields: [tenant_id], references: [tenant_id])
  user                    User               @relation("UserLoans", fields: [user_id], references: [user_id])
  payments                Payment[]

  @@map("loans")
}

model LoanSchedule {
  schedule_id        Int            @id @default(autoincrement())
  loan_id            Int
  tenant_id          Int // Mandatory for RLS
  installment_number Int

  due_date           DateTime       @db.Date
  principal_amount   Decimal        @db.Decimal(15, 2)
  interest_amount    Decimal        @db.Decimal(15, 2)
  total_due          Decimal        @db.Decimal(15, 2)
  status             ScheduleStatus @default(pending)
  paid_at            DateTime?
  days_late          Int            @default(0)
  penalty_applied    Decimal        @default(0) @db.Decimal(15, 2)
  loan               Loan           @relation(fields: [loan_id], references: [loan_id], onDelete: Cascade)
  tenant             Tenant         @relation(fields: [tenant_id], references: [tenant_id])

  @@index([tenant_id])
  @@map("loan_schedules")
}

model PaymentMethod {
  method_id      Int       @id @default(autoincrement())
  provider_name  String    @db.VarChar(100)
  account_number String?   @db.VarChar(100)
  is_active      Boolean   @default(true)
  tenant_id      Int
  tenant         Tenant    @relation(fields: [tenant_id], references: [tenant_id])
  payments       Payment[]

  @@map("payment_methods")
}

model Payment {
  payment_id        Int           @id @default(autoincrement())
  loan_id           Int
  tenant_id         Int // Mandatory for RLS
  method_id         Int
  payment_reference String        @unique @db.VarChar(100)
  amount_paid       Decimal       @db.Decimal(15, 2)
  receipt_url       String?       @db.VarChar(255)
  status            PaymentStatus @default(pending)
  submitted_at      DateTime      @default(now())
  verified_at       DateTime?
  verified_by       Int?
  notes             String?
  loan              Loan          @relation(fields: [loan_id], references: [loan_id])
  payment_method    PaymentMethod @relation(fields: [method_id], references: [method_id])
  verifier          User?         @relation("VerifiedPayments", fields: [verified_by], references: [user_id])
  tenant            Tenant        @relation(fields: [tenant_id], references: [tenant_id])

  @@index([tenant_id])
  @@map("payments")
}

model SavingsAccount {
  account_id   Int                  @id @default(autoincrement())
  tenant_id    Int
  user_id      Int
  account_type AccountType
  owner_role   Role?
  balance      Decimal              @default(0) @db.Decimal(15, 2)
  is_locked    Boolean              @default(false)
  lock_reason  String?              @db.VarChar(255)
  opened_at    DateTime             @default(now())
  updated_at   DateTime             @updatedAt
  tenant       Tenant               @relation(fields: [tenant_id], references: [tenant_id])
  user         User                 @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  transactions SavingsTransaction[]

  @@unique([user_id, account_type])
  @@index([tenant_id, account_type])
  @@index([tenant_id, owner_role])
  @@map("savings_accounts")
}

model SavingsTransaction {
  transaction_id           Int             @id @default(autoincrement())
  account_id               Int
  tenant_id                Int // Mandatory for RLS
  transaction_type         TransactionType
  amount                   Decimal         @db.Decimal(15, 2)
  fee_amount               Decimal         @default(0) @db.Decimal(15, 2)
  net_amount               Decimal?        @db.Decimal(15, 2)
  status                   PaymentStatus   @default(verified)
  method_label             String?         @db.VarChar(80)
  external_reference       String?         @db.VarChar(120)
  reference                String?         @db.VarChar(100)
  reconciliation_reference String?         @db.VarChar(120)
  ledger_transaction_id    String?
  issue_status             String          @default("none") @db.VarChar(50)
  issue_reported_at        DateTime?
  issue_notes              String?
  processed_at             DateTime        @default(now())
  processed_by             Int?
  account                  SavingsAccount  @relation(fields: [account_id], references: [account_id])
  processor                User?           @relation("ProcessedSavings", fields: [processed_by], references: [user_id])
  tenant                   Tenant          @relation(fields: [tenant_id], references: [tenant_id])

  @@index([tenant_id])
  @@index([account_id, status, processed_at])
  @@index([reconciliation_reference])
  @@index([ledger_transaction_id])
  @@index([issue_status])
  @@map("savings_transactions")
}

model AuditLog {
  log_id                  Int                 @id @default(autoincrement())
  tenant_id               Int?
  user_id                 Int?
  actor_role              Role?
  actor_label             String?             @db.VarChar(150)
  module                  AuditModule         @default(system)
  action                  String              @db.VarChar(100)
  action_category         AuditActionCategory @default(other)
  severity                AuditSeverity       @default(info)
  entity_type             String              @db.VarChar(80)
  entity_id               Int?
  entity_ref              String?             @db.VarChar(120)
  request_id              String?             @db.VarChar(120)
  session_id              String?             @db.VarChar(120)
  old_values              Json?
  new_values              Json?
  changed_fields          Json?
  ip_address              String?             @db.VarChar(45)
  user_agent              String?
  route                   String?             @db.VarChar(255)
  http_method             String?             @db.VarChar(12)
  city                    String?             @db.VarChar(100)
  region                  String?             @db.VarChar(100)
  is_cross_tenant_visible Boolean             @default(false)
  metadata                Json?
  created_at              DateTime            @default(now())
  tenant                  Tenant?             @relation(fields: [tenant_id], references: [tenant_id])
  user                    User?               @relation(fields: [user_id], references: [user_id])

  @@index([tenant_id, module, created_at])
  @@index([user_id, created_at])
  @@index([entity_type, entity_id])
  @@index([entity_ref])
  @@index([action_category, severity])
  @@index([request_id])
  @@index([session_id])
  @@index([is_cross_tenant_visible, created_at])
  @@map("audit_logs")
}

model ImbalanceInvestigation {
  id                                Int                          @id @default(autoincrement())
  tenant_id                         Int?
  source_module                     ImbalanceSourceModule
  source_entity_type                String?                      @db.VarChar(80)
  source_entity_id                  String?                      @db.VarChar(120)
  expected_amount                   Decimal                      @db.Decimal(15, 2)
  actual_amount                     Decimal                      @db.Decimal(15, 2)
  difference_amount                 Decimal                      @db.Decimal(15, 2)
  status                            ImbalanceInvestigationStatus @default(detected)
  priority                          String                       @default("normal") @db.VarChar(30)
  reconciliation_reference          String?                      @db.VarChar(120)
  related_ledger_transaction_id     String?
  related_wallet_transaction_id     Int?
  related_topup_request_id          Int?
  related_loan_id                   Int?
  related_payment_id                Int?
  assigned_to                       Int?
  assigned_at                       DateTime?
  detected_at                       DateTime                     @default(now())
  investigated_at                   DateTime?
  resolved_at                       DateTime?
  resolved_by                       Int?
  resolution_action                 ImbalanceResolutionAction?
  adjustment_ledger_transaction_id  String?
  adjustment_savings_transaction_id Int?
  audit_log_id                      Int?
  notes                             String?
  resolution_notes                  String?
  metadata                          Json?
  created_at                        DateTime                     @default(now())
  updated_at                        DateTime                     @updatedAt

  @@index([tenant_id, status, detected_at])
  @@index([source_module, source_entity_id])
  @@index([assigned_to, status])
  @@index([reconciliation_reference])
  @@index([related_ledger_transaction_id])
  @@index([related_wallet_transaction_id])
  @@index([related_topup_request_id])
  @@index([related_loan_id])
  @@index([related_payment_id])
  @@index([audit_log_id])
  @@map("imbalance_investigations")
}

model DailyReconciliation {
  id                               Int                        @id @default(autoincrement())
  tenant_id                        Int
  business_date                    DateTime                   @db.Date
  status                           DailyReconciliationStatus  @default(draft)
  total_disbursed                  Decimal                    @default(0) @db.Decimal(15, 2)
  disbursed_count                  Int                        @default(0)
  total_collected                  Decimal                    @default(0) @db.Decimal(15, 2)
  collected_count                  Int                        @default(0)
  total_ledger_debits              Decimal                    @default(0) @db.Decimal(15, 2)
  total_ledger_credits             Decimal                    @default(0) @db.Decimal(15, 2)
  is_ledger_balanced               Boolean                    @default(false)
  total_tenant_savings             Decimal                    @default(0) @db.Decimal(15, 2)
  total_treasury_balance           Decimal                    @default(0) @db.Decimal(15, 2)
  imbalance_amount                 Decimal                    @default(0) @db.Decimal(15, 2)
  has_discrepancy                  Boolean                    @default(false)
  signoff_blocked                  Boolean                    @default(false)
  block_reason                     String?
  reconciliation_reference         String                     @unique @db.VarChar(120)
  imbalance_investigation_id       Int?
  resolution_action                ImbalanceResolutionAction?
  resolution_reference             String?                    @db.VarChar(120)
  adjustment_ledger_transaction_id String?
  audit_log_id                     Int?
  prepared_by                      Int?
  prepared_at                      DateTime                   @default(now())
  signed_off_by                    Int?
  signed_off_at                    DateTime?
  approved_by                      Int?
  approved_at                      DateTime?
  approval_notes                   String?
  notes                            String?
  metadata                         Json?
  created_at                       DateTime                   @default(now())
  updated_at                       DateTime                   @updatedAt

  @@unique([tenant_id, business_date])
  @@index([tenant_id, status, business_date])
  @@index([imbalance_investigation_id])
  @@index([resolution_reference])
  @@index([adjustment_ledger_transaction_id])
  @@index([audit_log_id])
  @@index([signed_off_by])
  @@index([approved_by])
  @@map("daily_reconciliations")
}

model TrafficLog {
  id         String   @id @default(cuid())
  tenant_id  Int?
  path       String
  ip_address String?  @db.VarChar(45)
  city       String?  @db.VarChar(100)
  region     String?  @db.VarChar(100)
  user_agent String?
  created_at DateTime @default(now())
  tenant     Tenant?  @relation(fields: [tenant_id], references: [tenant_id])

  @@index([tenant_id, created_at])
  @@map("traffic_logs")
}

model InteractionLog {
  id         String   @id @default(cuid())
  tenant_id  Int?
  user_id    Int?
  event_type String   @db.VarChar(100)
  metadata   Json?
  ip_address String?  @db.VarChar(45)
  city       String?  @db.VarChar(100)
  region     String?  @db.VarChar(100)
  created_at DateTime @default(now())
  tenant     Tenant?  @relation(fields: [tenant_id], references: [tenant_id])
  user       User?    @relation(fields: [user_id], references: [user_id])

  @@index([tenant_id, event_type, created_at])
  @@map("interaction_logs")
}

model HomepageFaq {
  id                   Int      @id @default(autoincrement())
  tenant_id            Int?
  question             String   @db.VarChar(255)
  answer               String
  is_active            Boolean  @default(true)
  sort_order           Int      @default(0)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  season_tag           String?  @db.VarChar(100)
  workflow_status      String   @default("published") @db.VarChar(50)
  review_notes         String?
  submitted_by_user_id Int?
  reviewed_by_user_id  Int?
  tenant               Tenant?  @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)
  submitted_by_user    User?    @relation("FaqSubmitter", fields: [submitted_by_user_id], references: [user_id])
  reviewed_by_user     User?    @relation("FaqReviewer", fields: [reviewed_by_user_id], references: [user_id])

  @@index([tenant_id, workflow_status, is_active, sort_order])
  @@map("homepage_faqs")
}

model HomepageTestimonial {
  id                   Int      @id @default(autoincrement())
  tenant_id            Int?
  name                 String   @db.VarChar(150)
  role_label           String   @db.VarChar(150)
  photo_url            String?  @db.VarChar(255)
  content              String
  season_tag           String?  @db.VarChar(100)
  is_active            Boolean  @default(true)
  sort_order           Int      @default(0)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  workflow_status      String   @default("published") @db.VarChar(50)
  review_notes         String?
  submitted_by_user_id Int?
  reviewed_by_user_id  Int?
  tenant               Tenant?  @relation(fields: [tenant_id], references: [tenant_id], onDelete: Cascade)
  submitted_by_user    User?    @relation("TestimonialSubmitter", fields: [submitted_by_user_id], references: [user_id])
  reviewed_by_user     User?    @relation("TestimonialReviewer", fields: [reviewed_by_user_id], references: [user_id])

  @@index([tenant_id, workflow_status, is_active, sort_order])
  @@map("homepage_testimonials")
}

model FeedbackEntry {
  id                    Int             @id @default(autoincrement())
  tenant_id             Int?
  user_id               Int?
  name                  String          @db.VarChar(150)
  email                 String?         @db.VarChar(150)
  category              String          @db.VarChar(100)
  feedback_type         FeedbackType    @default(general)
  module_context        FeedbackModule  @default(general)
  related_entity_type   String?         @db.VarChar(80)
  related_entity_id     String?         @db.VarChar(120)
  wallet_transaction_id Int?
  loan_id               Int?
  payment_id            Int?
  topup_request_id      Int?
  support_ticket_id     Int?
  page_path             String?         @db.VarChar(255)
  subject               String?         @db.VarChar(255)
  message               String
  status                String          @default("open") @db.VarChar(50)
