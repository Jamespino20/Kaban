// ============================================================
// DM-31: Backup and Recovery
// ============================================================

enum BackupStatus {
  scheduled
  running
  completed
  failed
  expired
}

enum RestoreStatus {
  requested
  validating
  restoring
  completed
  failed
  cancelled
}

model BackupSchedule {
  id             Int                     @id @default(autoincrement())
  tenant_id      Int?
  frequency      ReportScheduleFrequency
  retention_days Int                     @default(30)
  last_run_at    DateTime?
  next_run_at    DateTime?
  storage_path   String?                 @db.VarChar(512)
  is_active      Boolean                 @default(true)
  created_by     Int?
  created_at     DateTime                @default(now())
  updated_at     DateTime                @updatedAt

  @@index([tenant_id, is_active])
  @@index([next_run_at])
  @@map("backup_schedules")
}

model BackupRecord {
  id               Int              @id @default(autoincrement())
  tenant_id        Int?
  schedule_id      Int?
  status           BackupStatus     @default(scheduled)
  storage_path     String?          @db.VarChar(512)
  file_size_bytes  BigInt?
  checksum         String?          @db.VarChar(128)
  affected_schemas String[]
  error_message    String?
  started_at       DateTime?
  completed_at     DateTime?
  expires_at       DateTime?
  created_by       Int?
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  restore_requests RestoreRequest[]

  @@index([tenant_id, status, created_at])
  @@index([schedule_id])
  @@map("backup_records")
}

model RestoreRequest {
  id             Int           @id @default(autoincrement())
  tenant_id      Int?
  backup_id      Int
  requested_by   Int
  status         RestoreStatus @default(requested)
  target_schemas String[]
  notes          String?
  error_message  String?
  approved_by    Int?
  approved_at    DateTime?
  started_at     DateTime?
  completed_at   DateTime?
  audit_log_id   Int?
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt
  backup         BackupRecord  @relation(fields: [backup_id], references: [id])

  @@index([tenant_id, status])
  @@index([backup_id])
  @@index([requested_by])
  @@map("restore_requests")
}

