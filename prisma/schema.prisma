enum FraudSignalType {
  duplicate_identity
  suspicious_transaction_pattern
  rapid_loan_cycling
  cross_tenant_default_risk
  velocity_breach
  device_anomaly
  manual_flag
}

enum FraudSignalStatus {
  detected
  under_review
  confirmed
  false_positive
  resolved
  escalated
}

model FraudSignal {
  id                 Int               @id @default(autoincrement())
  tenant_id          Int?
  signal_type        FraudSignalType
  status             FraudSignalStatus @default(detected)
  severity           AuditSeverity     @default(warning)
  linked_user_id     Int?
  linked_loan_id     Int?
  linked_payment_id  Int?
  linked_topup_id    Int?
  duplicate_user_id  Int?
  risk_score         Int?
  threshold_breached String?           @db.VarChar(120)
  signal_metadata    Json?
  assigned_to        Int?
  assigned_at        DateTime?
  reviewed_by        Int?
  reviewed_at        DateTime?
  resolution_notes   String?
  audit_log_id       Int?
  detected_at        DateTime          @default(now())
  resolved_at        DateTime?
  created_at         DateTime          @default(now())
  updated_at         DateTime          @updatedAt

  @@index([tenant_id, signal_type, status, detected_at])
  @@index([linked_user_id, status])
  @@index([linked_loan_id])
  @@index([severity, status])
  @@index([assigned_to, status])
  @@map("fraud_signals")
}

