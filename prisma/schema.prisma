model SystemFile {
  id              String   @id @default(cuid())
  tenant_id       Int?
  uploader_id     Int
  file_name       String   @db.VarChar(255)
  content_base64  String   @db.Text
  mime_type       String   @db.VarChar(100)
  size            Int
  created_at      DateTime @default(now())
  
  tenant          Tenant?  @relation(fields: [tenant_id], references: [tenant_id])
  uploader        User     @relation("FileUploader", fields: [uploader_id], references: [user_id])

  @@index([tenant_id])
  @@index([uploader_id])
  @@map("system_files")
}

