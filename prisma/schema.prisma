enum AiUseCase {
  portfolio_summary
  risk_detection
  repayment_forecast
  member_financial_tip
  anomaly_alert
  support_draft
}

enum AiProcessingStatus {
  queued
  processing
  completed
  failed
  skipped
}

model AiConfig {
  id                  Int          @id @default(autoincrement())
  tenant_id           Int?
  use_case            AiUseCase
  is_enabled          Boolean      @default(true)
  risk_sensitivity    String       @default("medium") @db.VarChar(20)
  prompt_template     String?      @db.Text
  max_tokens          Int          @default(512)
  temperature         Decimal      @default(0.3) @db.Decimal(3, 2)
  allowed_data_scopes String[]
  created_at          DateTime     @default(now())
  updated_at          DateTime     @updatedAt
  snapshots           AiSnapshot[]

  @@unique([tenant_id, use_case])
  @@index([tenant_id, is_enabled])
  @@map("ai_configs")
}

model AiSnapshot {
  id               Int                @id @default(autoincrement())
  config_id        Int?
  tenant_id        Int?
  use_case         AiUseCase
  status           AiProcessingStatus @default(queued)
  input_summary    Json?
  output_text      String?            @db.Text
  risk_level       String?            @db.VarChar(20)
  confidence_score Decimal?           @db.Decimal(5, 2)
  requires_review  Boolean            @default(false)
  reviewed_by      Int?
  reviewed_at      DateTime?
  review_notes     String?
  error_message    String?
  processing_ms    Int?
  period_start     DateTime?
  period_end       DateTime?
  metadata         Json?
  created_at       DateTime           @default(now())
  updated_at       DateTime           @updatedAt
  config           AiConfig?          @relation(fields: [config_id], references: [id])

  @@index([tenant_id, use_case, created_at])
  @@index([status])
  @@index([requires_review, reviewed_at])
  @@map("ai_snapshots")
}

